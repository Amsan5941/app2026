# ============================================================
# Backend Environment Variables — copy to backend/.env and fill in
# ============================================================

# ── OpenAI (required for AI food recognition) ─────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Supabase (use SERVICE ROLE key, not anon key) ─────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Storage bucket name (optional — leave blank to skip image uploads)
# SUPABASE_STORAGE_BUCKET=food-images

# ── USDA FoodData Central (optional, for nutrition lookup) ────
# Get from: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# ── Custom ML Model (optional) ────────────────────────────────
CUSTOM_MODEL_PATH=models/food_classifier.pth
USE_CUSTOM_MODEL=false
CUSTOM_MODEL_CONFIDENCE_THRESHOLD=0.75

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ── CORS (docker-compose overrides this automatically) ────────
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:3000

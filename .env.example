# ============================================================
# Frontend Environment Variables — copy to .env and fill in
# ============================================================

# ── Supabase (get from Supabase Dashboard → Settings → API) ──
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Backend API ───────────────────────────────────────────────
# For Docker: keep as http://localhost:8000/api/v1 (browser accesses via published port)
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000/api/v1

# ── Sentry (optional — leave blank to disable crash reporting) ─
EXPO_PUBLIC_SENTRY_DSN=

# ── PostHog Analytics (optional — leave blank to disable) ─────
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
